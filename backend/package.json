{
  "name": "nieruchomosciai-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NieruchomościAI — backend API (analiza ogłoszeń mieszkaniowych z AI, dual segment Consumer/Investor)",
  "engines": {
    "node": ">=22.5.0"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/index.js",
    "dev": "node --disable-warning=ExperimentalWarning --watch src/index.js",
    "migrate": "node --disable-warning=ExperimentalWarning src/db/migrate.js",
    "seed": "node --disable-warning=ExperimentalWarning src/db/seed.js",
    "fetch:listings": "node --disable-warning=ExperimentalWarning src/jobs/fetchListings.js --once",
    "fetch:domiporta": "node --disable-warning=ExperimentalWarning src/jobs/fetchListings.js --source=domiporta --once",
    "fetch:olx": "node --disable-warning=ExperimentalWarning src/jobs/fetchListings.js --source=olx --once",
    "daily:run": "node --disable-warning=ExperimentalWarning src/jobs/dailyMatch.js --skip-fetch",
    "daily:run-with-fetch": "node --disable-warning=ExperimentalWarning src/jobs/dailyMatch.js",
    "backup": "node --disable-warning=ExperimentalWarning src/services/backup.js",
    "test": "node --disable-warning=ExperimentalWarning --test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@sentry/node": "^10.53.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.12.3",
    "rss-parser": "^3.13.0",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  }
}
